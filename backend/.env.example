# Email credentials for Nodemailer (Gmail SMTP)
# NEVER commit this file to GitHub — it is in .gitignore

EMAIL_USER=BalentineTechSolutions@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Server port (optional — defaults to 3001)
PORT=3001

# ─── Stripe ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...        # from Dashboard > Developers > Webhooks

# Stripe Price IDs — create subscription products in Dashboard > Products
# then paste the Price ID (price_xxx) for each plan here
STRIPE_PRICE_STARTER=price_...         # e.g. $97/month Starter plan
STRIPE_PRICE_PRO=price_...             # e.g. $297/month Pro plan

# Frontend origin — used for Stripe success/cancel redirect URLs
FRONTEND_URL=https://d3mlam2b9qbwyy.cloudfront.net   # production CloudFront URL
# FRONTEND_URL=http://localhost:5173                  # local dev

# ─── Encryption ────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting PII (customer emails) at rest in PostgreSQL.
# Generate a fresh key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). NEVER commit the real value.
ENCRYPTION_KEY=your_64_hex_char_key_here

# ─── HeyGen AI Video ───────────────────────────────────────────────────────
# Get your API key from https://app.heygen.com → Settings → API
# NEVER commit the real value — store it here and in AWS SSM/EB env vars.
HEYGEN_API_KEY=your_heygen_api_key_here
